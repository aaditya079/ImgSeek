<Window x:Class="ImgSeek.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ImgSeek" Height="820" Width="1100"
        MinHeight="620" MinWidth="860"
        Background="#0A0E1A" FontFamily="Segoe UI"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <!-- Smooth color animation helper -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding" Value="20,10"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                CornerRadius="9" Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform><TranslateTransform x:Name="TT"/></Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <EventTrigger RoutedEvent="MouseEnter">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TT" Storyboard.TargetProperty="Y"
                                                         To="-2" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity"
                                                         To="0.88" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <EventTrigger RoutedEvent="MouseLeave">
                                <BeginStoryboard>
                                    <Storyboard>
                                        <DoubleAnimation Storyboard.TargetName="TT" Storyboard.TargetProperty="Y"
                                                         To="0" Duration="0:0:0.12"/>
                                        <DoubleAnimation Storyboard.TargetName="Bd" Storyboard.TargetProperty="Opacity"
                                                         To="1" Duration="0:0:0.12"/>
                                    </Storyboard>
                                </BeginStoryboard>
                            </EventTrigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Bd" Property="RenderTransform">
                                    <Setter.Value>
                                        <ScaleTransform ScaleX="0.96" ScaleY="0.96"/>
                                    </Setter.Value>
                                </Setter>
                                <Setter TargetName="Bd" Property="Opacity" Value="0.75"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Bd" Property="Opacity" Value="0.35"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- TextBox -->
        <Style x:Key="InputBox" TargetType="TextBox">
            <Setter Property="Background" Value="#131929"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="CaretBrush" Value="#60A5FA"/>
            <Setter Property="SelectionBrush" Value="#3B82F6"/>
            <Setter Property="BorderBrush" Value="#FFFFFF2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="14,0,14,0"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                Padding="{TemplateBinding Padding}"
                                CornerRadius="9">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Focusable="False"
                                          HorizontalScrollBarVisibility="Hidden"
                                          VerticalScrollBarVisibility="Hidden"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsFocused" Value="True">
                                <Setter TargetName="Bd" Property="BorderBrush" Value="#3B82F6"/>
                                <Setter TargetName="Bd" Property="Background" Value="#1A2744"/>
                                <Setter TargetName="Bd" Property="Effect">
                                    <Setter.Value>
                                        <DropShadowEffect Color="#3B82F6" BlurRadius="6" ShadowDepth="0" Opacity="0.45"/>
                                    </Setter.Value>
                                </Setter>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Progress bar -->
        <Style x:Key="GlowProgress" TargetType="ProgressBar">
            <Setter Property="Height" Value="5"/>
            <Setter Property="Background" Value="#1E293B"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ProgressBar">
                        <Border Background="{TemplateBinding Background}" CornerRadius="3" ClipToBounds="True">
                            <Border x:Name="PART_Indicator" HorizontalAlignment="Left" CornerRadius="3">
                                <Border.Background>
                                    <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                                        <GradientStop Color="#60A5FA" Offset="0"/>
                                        <GradientStop Color="#3B82F6" Offset="0.5"/>
                                        <GradientStop Color="#818CF8" Offset="1"/>
                                    </LinearGradientBrush>
                                </Border.Background>
                            </Border>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ScrollBar -->
        <Style TargetType="ScrollBar">
            <Setter Property="Width" Value="6"/>
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ScrollBar">
                        <Grid>
                            <Track x:Name="PART_Track" IsDirectionReversed="True">
                                <Track.Thumb>
                                    <Thumb>
                                        <Thumb.Template>
                                            <ControlTemplate TargetType="Thumb">
                                                <Border Background="#FFFFFF22" CornerRadius="3" Margin="1"/>
                                            </ControlTemplate>
                                        </Thumb.Template>
                                    </Thumb>
                                </Track.Thumb>
                            </Track>
                        </Grid>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Sleek CheckBox Style -->
        <Style x:Key="SleekCheck" TargetType="CheckBox">
            <Setter Property="Foreground" Value="#94A3B8"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Margin" Value="0,0,24,0"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="#FFFFFF"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Dark ComboBox Style -->
        <Style x:Key="DarkComboBox" TargetType="ComboBox">
            <Setter Property="Background" Value="#131929"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#FFFFFF2A"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Height" Value="32"/>
            <Setter Property="ItemContainerStyle">
                <Setter.Value>
                    <Style TargetType="ComboBoxItem">
                        <Setter Property="Background" Value="#131929"/>
                        <Setter Property="Foreground" Value="White"/>
                        <Setter Property="Padding" Value="8,4"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#1E293B"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#3B82F6"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.Background>
            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                <GradientStop Color="#060913" Offset="0"/>
                <GradientStop Color="#0B1120" Offset="0.5"/>
                <GradientStop Color="#050810" Offset="1"/>
            </LinearGradientBrush>
        </Grid.Background>
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Hero header -->
            <RowDefinition Height="Auto"/>   <!-- Search bar -->
            <RowDefinition Height="Auto"/>   <!-- Progress strip -->
            <RowDefinition Height="Auto"/>   <!-- Message bar -->
            <RowDefinition Height="*"/>      <!-- Results area -->
            <RowDefinition Height="Auto"/>   <!-- Action footer -->
        </Grid.RowDefinitions>

        <!-- ══════════════════ HERO HEADER ══════════════════ -->
        <Border Grid.Row="0" Padding="36,26,36,22">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0B1120B8" Offset="0"/>
                    <GradientStop Color="#060913A0" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>
                <!-- Logo + title -->
                <StackPanel DockPanel.Dock="Left" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="🔍" FontSize="28" VerticalAlignment="Center" Margin="0,0,10,0"/>
                        <TextBlock FontSize="26" FontWeight="Bold" VerticalAlignment="Center">
                            <Run Foreground="White">ImgSeek</Run>
                            <Run Foreground="#818CF8"> — Image Name Searcher</Run>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock Margin="38,5,0,0" Foreground="#64748B" FontSize="12.5">
                        Scan folders with Windows OCR to find images containing any name or keyword
                    </TextBlock>
                </StackPanel>
                <!-- Version badge -->
                <Border DockPanel.Dock="Right" VerticalAlignment="Center" HorizontalAlignment="Right"
                        Background="#1E293B" CornerRadius="20" Padding="12,5"
                        BorderBrush="#FFFFFF12" BorderThickness="1">
                    <TextBlock Text="v2.0 WPF" Foreground="#64748B" FontSize="11" FontWeight="SemiBold"/>
                </Border>
            </DockPanel>
        </Border>

        <!-- Thin accent line under header -->
        <Rectangle Grid.Row="0" Height="1" VerticalAlignment="Bottom">
            <Rectangle.Fill>
                <LinearGradientBrush StartPoint="0,0" EndPoint="1,0">
                    <GradientStop Color="Transparent" Offset="0"/>
                    <GradientStop Color="#3B82F6" Offset="0.3"/>
                    <GradientStop Color="#818CF8" Offset="0.7"/>
                    <GradientStop Color="Transparent" Offset="1"/>
                </LinearGradientBrush>
            </Rectangle.Fill>
        </Rectangle>

        <!-- ══════════════════ SEARCH BAR ══════════════════ -->
        <Border Grid.Row="1" Background="#060913B0" Padding="28,14" BorderBrush="#FFFFFF06" BorderThickness="0,0,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Input Row -->
                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="90"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="220"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Folder path -->
                    <Grid Grid.Column="0">
                        <TextBox x:Name="FolderBox" Style="{StaticResource InputBox}" Height="42"/>
                        <TextBlock x:Name="FolderHintTb" Text="📁  Folder to scan…" IsHitTestVisible="False"
                                   Foreground="#374151" FontSize="13" Margin="15,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <Button Grid.Column="2" Content="Browse" Height="42"
                            Style="{StaticResource BtnBase}" Background="#1E293B"
                            Foreground="#94A3B8" Click="Browse_Click"/>

                    <!-- Search term -->
                    <Grid Grid.Column="4">
                        <TextBox x:Name="SearchBox" Style="{StaticResource InputBox}" Height="42"
                                 KeyDown="SearchBox_KeyDown"/>
                        <TextBlock x:Name="SearchHintTb" Text="🔤  Keywords (separated by ; or ,)…" IsHitTestVisible="False"
                                   Foreground="#374151" FontSize="13" Margin="15,0,0,0"
                                   VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Scan -->
                    <Button x:Name="ScanBtn" Grid.Column="6" Height="42"
                            Style="{StaticResource BtnBase}" Click="Scan_Click" Padding="22,10">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#3B82F6" Offset="0"/>
                                <GradientStop Color="#6366F1" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚡" Margin="0,0,6,0"/>
                            <TextBlock Text="Scan"/>
                        </StackPanel>
                    </Button>

                    <!-- Cancel -->
                    <Button x:Name="CancelBtn" Grid.Column="8" Height="42"
                            Style="{StaticResource BtnBase}" IsEnabled="False"
                            Click="Cancel_Click" Padding="16,10"
                            Background="#1F1010" Foreground="#F87171">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✕" Margin="0,0,6,0"/>
                            <TextBlock Text="Cancel"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <!-- Options Row -->
                <Grid Grid.Row="2">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="180"/>
                        <ColumnDefinition Width="24"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="Language:" Foreground="#64748B" FontSize="13" VerticalAlignment="Center"/>
                    <ComboBox x:Name="LanguageSelect" Grid.Column="2" Style="{StaticResource DarkComboBox}" VerticalAlignment="Center" Width="180"/>

                    <StackPanel Grid.Column="4" Orientation="Horizontal" VerticalAlignment="Center">
                        <CheckBox x:Name="CaseSensitiveCheck" Content="Match Case" Style="{StaticResource SleekCheck}"/>
                        <CheckBox x:Name="RegexCheck" Content="Use Regex" Style="{StaticResource SleekCheck}"/>
                        <CheckBox x:Name="MatchAllCheck" Content="Match All Keywords (AND)" Style="{StaticResource SleekCheck}"/>
                    </StackPanel>
                </Grid>
            </Grid>
        </Border>

        <!-- ══════════════════ PROGRESS STRIP ══════════════════ -->
        <Border x:Name="ProgressPanel" Grid.Row="2" Background="#080D18"
                Padding="28,10" Visibility="Collapsed"
                BorderBrush="#FFFFFF08" BorderThickness="0,1,0,1">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0">
                    <TextBlock x:Name="ProgressPct" DockPanel.Dock="Right" Typography.NumeralAlignment="Tabular"
                               Foreground="#60A5FA" FontWeight="Bold" FontSize="13" Margin="10,0,0,0">0%</TextBlock>
                    <TextBlock x:Name="ProgressStats" Foreground="#475569" FontSize="12" Typography.NumeralAlignment="Tabular">Initialising…</TextBlock>
                </DockPanel>
                <ProgressBar x:Name="ProgressBar" Grid.Row="1" Style="{StaticResource GlowProgress}" Margin="0,5"/>
                <DockPanel Grid.Row="2">
                    <TextBlock x:Name="MatchStats" DockPanel.Dock="Right" Typography.NumeralAlignment="Tabular"
                               Foreground="#818CF8" FontSize="12" FontWeight="SemiBold"/>
                    <TextBlock x:Name="ProgressFile" Foreground="#334155" FontSize="11"
                               TextTrimming="CharacterEllipsis"/>
                </DockPanel>
            </Grid>
        </Border>

        <!-- ══════════════════ MESSAGE BAR ══════════════════ -->
        <Border x:Name="MsgBar" Grid.Row="3" Padding="24,10" Visibility="Collapsed">
            <DockPanel>
                <Button DockPanel.Dock="Right" Content="✕" Click="DismissMsg_Click"
                        Background="Transparent" BorderThickness="0"
                        Foreground="#FFFFFF50" Cursor="Hand" FontSize="14" Padding="10,0"/>
                <TextBlock x:Name="MsgText" VerticalAlignment="Center" FontSize="13" TextWrapping="Wrap"/>
            </DockPanel>
        </Border>

        <!-- ══════════════════ RESULTS ══════════════════ -->
        <Grid Grid.Row="4">

            <!-- Empty / placeholder state -->
            <StackPanel x:Name="EmptyState" VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock x:Name="EmptyIcon" Text="🔎" FontSize="64"
                           HorizontalAlignment="Center" Opacity="0.3"/>
                <TextBlock x:Name="EmptyMsg"
                           Text="Ready to search your images"
                           Foreground="#94A3B8" FontSize="16" FontWeight="SemiBold"
                           HorizontalAlignment="Center" Margin="0,14,0,0"/>
                <TextBlock Text="Enter folder paths separated by semicolons and click Scan"
                           Foreground="#475569" FontSize="13"
                           HorizontalAlignment="Center" Margin="0,6,0,0"/>
            </StackPanel>

            <!-- Results grid -->
            <ScrollViewer x:Name="ResultsScroll" Visibility="Collapsed"
                          VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled"
                          Background="Transparent">
                <StackPanel x:Name="ResultsStack" Margin="18,16,18,16"/>
            </ScrollViewer>
        </Grid>

        <!-- ══════════════════ ACTION FOOTER ══════════════════ -->
        <Border x:Name="FooterBar" Grid.Row="5" Padding="28,14"
                BorderBrush="#FFFFFF0A" BorderThickness="0,1,0,0"
                Visibility="Collapsed">
            <Border.Background>
                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                    <GradientStop Color="#0D1117" Offset="0"/>
                    <GradientStop Color="#080D18" Offset="1"/>
                </LinearGradientBrush>
            </Border.Background>
            <DockPanel>
                <TextBlock x:Name="FooterCount" DockPanel.Dock="Right" Typography.NumeralAlignment="Tabular"
                           Foreground="#818CF8" FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
                <StackPanel Orientation="Horizontal">
                    <Button Content="📋  Copy All Paths" Click="CopyPaths_Click"
                            Style="{StaticResource BtnBase}" Margin="0,0,10,0"
                            Padding="18,10" Background="#1E293B" Foreground="#94A3B8"/>
                    <Button Content="📁  Copy Photos To…" Click="CopyPhotos_Click"
                            Style="{StaticResource BtnBase}" Margin="0,0,10,0" Padding="18,10">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#1D4ED8" Offset="0"/>
                                <GradientStop Color="#4338CA" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <Button Content="🌐  Open HTML Gallery" Click="OpenGallery_Click"
                            Style="{StaticResource BtnBase}" Margin="0,0,10,0" Padding="18,10">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#059669" Offset="0"/>
                                <GradientStop Color="#0D9488" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                    <Button Content="📥  Export Matches…" Click="ExportMatches_Click"
                            Style="{StaticResource BtnBase}" Padding="18,10">
                        <Button.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#4F46E5" Offset="0"/>
                                <GradientStop Color="#7C3AED" Offset="1"/>
                            </LinearGradientBrush>
                        </Button.Background>
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</Window>
